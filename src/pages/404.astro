---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Page Not Found — EMI" description="The page you are looking for could not be found. Return to the Equipment Management International homepage to explore our mining maintenance solutions.">
  <Nav />
  <main class="pt-20 min-h-[60vh] flex items-center justify-center">
    <div class="text-center px-4">
      <h1 class="text-6xl font-extrabold text-emi-gold mb-4">404</h1>
      <p class="text-xl text-gray-600 mb-8">The page you're looking for doesn't exist.</p>
      <a href="/" class="px-6 py-3 bg-emi-charcoal text-white font-semibold rounded-lg hover:bg-emi-black transition-colors">
        Back to Home
      </a>
    </div>
  </main>
  <Footer />
</Layout>
