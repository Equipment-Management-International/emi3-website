---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import PageHero from '../components/PageHero.astro';
import QuoteBlock from '../components/QuoteBlock.astro';
import CTABanner from '../components/CTABanner.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="What We Do — Equipment Management International" description="Discover how EMI helps mining operations improve fleet reliability, reduce costs, and achieve 30-40% maintenance improvements through site reviews and software.">
  <Nav transparent />
  <main id="top">
    <!-- Hero with embedded stats -->
    <PageHero
      title="Transforming Maintenance Outcomes for Australia's Mining Operations"
      subtitle="Proven results for Tier 1 and 2 mining companies since 2005."
      image="/images/hero/what-we-do.jpg"
    >
      <div class="flex flex-wrap gap-3 mt-4">
        <div class="glass-panel-light rounded-lg px-5 py-3 text-center">
          <div class="text-2xl font-bold text-primary">40%</div>
          <div class="text-xs text-white/70">Fewer breakdowns</div>
        </div>
        <div class="glass-panel-light rounded-lg px-5 py-3 text-center">
          <div class="text-2xl font-bold text-primary">30%+</div>
          <div class="text-xs text-white/70">Faster PM times</div>
        </div>
        <div class="glass-panel-light rounded-lg px-5 py-3 text-center">
          <div class="text-2xl font-bold text-primary">3 mo</div>
          <div class="text-xs text-white/70">To global MTBF</div>
        </div>
        <a href="/take-action" class="btn btn-primary btn-md self-center ml-1">
          Book a Site Review
        </a>
      </div>
    </PageHero>

    <!-- Philosophy quote -->
    <section class="py-12 sm:py-16 bg-base-100">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <QuoteBlock variant="large">
          "Your philosophy defines your attitude which determines your actions, which creates your results."
        </QuoteBlock>
      </div>
    </section>

    <!-- The challenge -->
    <section class="py-16 sm:py-24 bg-base-200">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="section-heading mb-8">Does This Sound Like Your Site?</h2>

        <div class="grid sm:grid-cols-2 gap-4 mb-10">
          {[
            'Fleet reliability and availability is declining',
            'Maintenance costs keep increasing',
            'Initiatives have been put in place but aren\'t working',
            'Workforce experience varies — results are inconsistent',
            'Paper-based processes are slowing everything down',
            'Knowledge lost through high staff turnover',
          ].map((item) => (
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-error flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" /></svg>
              <span class="prose-body">{item}</span>
            </div>
          ))}
        </div>

        <p class="prose-body max-w-3xl">
          Our clients faced the same challenges. The root causes are remarkably consistent across mining operations. The good news? The solutions are simple — and they work every time. It starts with a management team prepared to support change.
        </p>
      </div>
    </section>

    <!-- How it works: Site Review -->
    <section class="py-16 sm:py-24 bg-base-100">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="section-heading mb-10">It All Starts With a Site Review</h2>

        <div class="grid sm:grid-cols-3 gap-8 mb-10">
          <div>
            <div class="w-10 h-10 rounded-full bg-primary text-primary-content flex items-center justify-center text-lg font-bold mb-4">1</div>
            <h3 class="section-subheading mb-2">We Come to You</h3>
            <p class="prose-body">5–7 days on your site. We study your methods, run time-and-motion studies, and interview key personnel at all levels.</p>
          </div>
          <div>
            <div class="w-10 h-10 rounded-full bg-primary text-primary-content flex items-center justify-center text-lg font-bold mb-4">2</div>
            <h3 class="section-subheading mb-2">Present Findings</h3>
            <p class="prose-body">Before we leave, we present our findings to your team. Direct, fact-based, and sometimes confronting.</p>
          </div>
          <div>
            <div class="w-10 h-10 rounded-full bg-primary text-primary-content flex items-center justify-center text-lg font-bold mb-4">3</div>
            <h3 class="section-subheading mb-2">Deliver Solutions</h3>
            <p class="prose-body">A comprehensive report with implementation solutions tailored to your site, team, and budget.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Steven Johnson quote -->
    <section class="py-10 sm:py-14 bg-base-200">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <QuoteBlock variant="large" attribution="Steven Johnson, author">
          "Innovation doesn't come just from giving people incentives; it comes from creating environments where their ideas can connect."
        </QuoteBlock>
      </div>
    </section>

    <!-- CTA -->
    <CTABanner
      heading="Smart Asset Managers Know When to Ask for Help"
      subtitle="Take the first step toward transforming your maintenance operations."
      primaryLabel="Book a Site Review"
      primaryHref="/take-action"
      secondaryLabel="Contact Us"
      secondaryHref="/contact"
    />
  </main>
  <Footer />
</Layout>
