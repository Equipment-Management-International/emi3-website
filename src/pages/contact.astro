---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Contact — Equipment Management International" description="Get in touch with Equipment Management International for a consultation, demo access, or to discuss maintenance software solutions for your mining operation.">
  <Nav />
  <main id="top" class="pt-20">
    <section class="py-16 sm:py-24">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-5 gap-12">
          <!-- Company details -->
          <div class="lg:col-span-2">
            <h1 class="section-heading mb-4">
              Contact Us
            </h1>
            <p class="prose-body mb-8">
              Get in touch for a consultation, demo access, or to discuss how we can help streamline your maintenance operations.
            </p>

            <div class="space-y-4 text-base-content/80">
              <div>
                <p class="font-semibold text-base-content">Equipment Management International P/L</p>
                <p>ABN 45 112 360 273</p>
              </div>
              <div>
                <p>Burnie, TAS, 7320</p>
                <p>Australia</p>
              </div>
              <p class="text-primary font-medium italic">
                A proud Tasmanian based company, developing all our software in-house, locally for global use.
              </p>
            </div>
          </div>

          <!-- Contact form -->
          <div class="lg:col-span-3">
            <div class="card bg-base-200">
              <div class="card-body">
                <form class="space-y-5" action="#" method="POST" name="contact" data-netlify="true">
                  <input type="hidden" name="form-name" value="contact" />

                  <div class="grid sm:grid-cols-2 gap-5">
                    <fieldset class="fieldset">
                      <label class="label" for="first-name">First Name *</label>
                      <input type="text" id="first-name" name="first-name" required class="input input-bordered w-full" />
                    </fieldset>
                    <fieldset class="fieldset">
                      <label class="label" for="last-name">Last Name *</label>
                      <input type="text" id="last-name" name="last-name" required class="input input-bordered w-full" />
                    </fieldset>
                  </div>

                  <fieldset class="fieldset">
                    <label class="label" for="email">Email Address *</label>
                    <input type="email" id="email" name="email" required class="input input-bordered w-full" />
                  </fieldset>

                  <fieldset class="fieldset">
                    <label class="label" for="subject">Subject *</label>
                    <input type="text" id="subject" name="subject" required class="input input-bordered w-full" />
                  </fieldset>

                  <fieldset class="fieldset">
                    <label class="label" for="message">Message *</label>
                    <textarea id="message" name="message" rows="5" required class="textarea textarea-bordered w-full"></textarea>
                  </fieldset>

                  <button type="submit" class="btn btn-primary btn-lg w-full sm:w-auto">
                    Send Message
                  </button>
                </form>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
