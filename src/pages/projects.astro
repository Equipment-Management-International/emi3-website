---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Projects — Equipment Management International" description="Explore EMI project case studies including ZoneMaintenance development, Cat 789C truck assembly, workshop design, and maintenance strategy consulting.">
  <Nav />
  <main id="top" class="pt-20">
    <!-- Hero -->
    <section class="bg-neutral text-neutral-content py-16 sm:py-24">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h1 class="text-3xl sm:text-4xl font-bold mb-6">
          Projects
        </h1>
        <p class="text-lg text-neutral-content/80 max-w-3xl mx-auto">
          A selection of projects that demonstrate our experience and the results we deliver
        </p>
      </div>
    </section>

    <!-- Project Cards -->
    <section class="py-16 sm:py-24 bg-base-100">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid md:grid-cols-2 gap-8">
          <!-- Project 1: ZoneMaintenance -->
          <div class="card bg-base-100 shadow-md hover:shadow-xl transition-shadow">
            <figure>
              <img
                src="/images/projects/mining-1.jpg"
                alt="Mining equipment on site"
                class="w-full h-56 object-cover"
              />
            </figure>
            <div class="card-body">
              <div class="badge badge-primary badge-outline uppercase tracking-wide text-xs">
                Software Development
              </div>
              <h3 class="card-title mt-2">ZoneMaintenance — Origin Story</h3>
              <p class="prose-body">
                Developed in 2006 for an owner miner during a massive mine expansion project. The system focuses on reducing PM servicing times by performing maintenance during refuelling windows.
              </p>
              <div class="bg-base-200 rounded-lg p-4 my-3">
                <p class="text-base text-base-content/70 mb-1">Key Achievement</p>
                <p class="text-primary font-bold text-lg">33% reduction in service time</p>
                <p class="text-base text-base-content/70">achieved during initial trials, with larger services completing approximately 85% of work during refuelling periods.</p>
              </div>
              <p class="text-base text-base-content/70">
                Applied to underground operations in 2009, achieving 30-50% service time reductions. Software commercialised in 2015 and implemented across Australia, China, and PNG.
              </p>
            </div>
          </div>

          <!-- Project 2: Cat 789C -->
          <div class="card bg-base-100 shadow-md hover:shadow-xl transition-shadow">
            <div class="card-body">
              <div class="badge badge-primary badge-outline uppercase tracking-wide text-xs">
                Equipment Assembly
              </div>
              <h3 class="card-title mt-2">Caterpillar 789C Truck Assembly</h3>
              <p class="prose-body">
                Assembly of 13 brand new Cat 789C trucks on-site within 3 months. A complex logistics and engineering challenge requiring precise coordination.
              </p>
              <div class="bg-base-200 rounded-lg p-4 my-3">
                <p class="text-base text-base-content/70 mb-1">Outcome</p>
                <p class="text-primary font-bold">Completed safely, under budget, and on schedule</p>
                <p class="text-base text-base-content/70">with 3-4 trucks assembled simultaneously</p>
              </div>
            </div>
          </div>

          <!-- Project 3: Workshop Design -->
          <div class="card bg-base-100 shadow-md hover:shadow-xl transition-shadow">
            <div class="card-body">
              <div class="badge badge-primary badge-outline uppercase tracking-wide text-xs">
                Facility Design
              </div>
              <h3 class="card-title mt-2">Workshop Design — Reliability Centre</h3>
              <p class="prose-body">
                Design of drive-through refuelling facility, main workshop, and offices for a large mining company.
              </p>
              <div class="bg-base-200 rounded-lg p-4 my-3">
                <p class="text-base text-base-content/70 mb-1">Design Partner</p>
                <p class="font-semibold">Pitt and Sherry (Launceston-based)</p>
              </div>
              <p class="text-base text-base-content/70">
                The deliverable was a comprehensive "Reliability Centre" designed to optimise maintenance workflows and equipment throughput.
              </p>
            </div>
          </div>

          <!-- Project 4: R2900G Strategy -->
          <div class="card bg-base-100 shadow-md hover:shadow-xl transition-shadow">
            <div class="card-body">
              <div class="badge badge-primary badge-outline uppercase tracking-wide text-xs">
                Strategy Consulting
              </div>
              <h3 class="card-title mt-2">Caterpillar R2900G Maintenance Strategy</h3>
              <p class="prose-body">
                Strategy development for a Tier 1 Australian gold mining company managing a fleet of Cat R2900G LHD boggers in underground operations.
              </p>
              <div class="bg-base-200 rounded-lg p-4">
                <p class="text-base text-base-content/70 mb-1">Collaboration</p>
                <p class="font-semibold">Caterpillar Dealer & Caterpillar Underground</p>
                <p class="text-base text-base-content/70">Strategy development consulting for optimal fleet maintenance outcomes</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-16 sm:py-24 bg-neutral text-neutral-content">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="section-heading text-neutral-content mb-4">
          Let's Discuss Your Project
        </h2>
        <p class="text-neutral-content/80 mb-8 text-lg">
          Whether it's software implementation, strategy consulting, or facility design, we can help.
        </p>
        <a href="/contact" class="btn btn-primary btn-lg">
          Contact Us
        </a>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
