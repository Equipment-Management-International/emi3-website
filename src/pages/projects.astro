---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Projects — Equipment Management International">
  <Nav />
  <main class="pt-20">
    <!-- Hero -->
    <section class="bg-emi-charcoal text-white py-16 sm:py-24 scroll-mt-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold uppercase tracking-wide mb-6">
          Projects
        </h1>
        <p class="text-xl text-gray-300 max-w-3xl mx-auto">
          A selection of projects that demonstrate our experience and the results we deliver
        </p>
      </div>
    </section>

    <!-- Project Cards -->
    <section class="py-16 sm:py-24 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid md:grid-cols-2 gap-8">
          <!-- Project 1: ZoneMaintenance -->
          <div class="rounded-xl border border-gray-200 bg-white p-8 hover:shadow-lg transition-shadow">
            <div class="inline-block px-3 py-1 rounded-full bg-emi-gold/10 text-emi-gold text-xs font-semibold mb-4 uppercase tracking-wide">
              Software Development
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-4">ZoneMaintenance — Origin Story</h3>
            <p class="text-gray-700 mb-4">
              Developed in 2006 for an owner miner during a massive mine expansion project. The system focuses on reducing PM servicing times by performing maintenance during refuelling windows.
            </p>
            <div class="bg-emi-gray rounded-lg p-4 mb-4">
              <p class="text-sm text-gray-600 mb-1">Key Achievement</p>
              <p class="text-emi-gold font-bold text-lg">33% reduction in service time</p>
              <p class="text-sm text-gray-600">achieved during initial trials, with larger services completing approximately 85% of work during refuelling periods.</p>
            </div>
            <p class="text-gray-700 text-sm">
              Applied to underground operations in 2009, achieving 30-50% service time reductions. Software commercialised in 2015 and implemented across Australia, China, and PNG.
            </p>
          </div>

          <!-- Project 2: Cat 789C -->
          <div class="rounded-xl border border-gray-200 bg-white p-8 hover:shadow-lg transition-shadow">
            <div class="inline-block px-3 py-1 rounded-full bg-emi-gold/10 text-emi-gold text-xs font-semibold mb-4 uppercase tracking-wide">
              Equipment Assembly
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-4">Caterpillar 789C Truck Assembly</h3>
            <p class="text-gray-700 mb-4">
              Assembly of 13 brand new Cat 789C trucks on-site within 3 months. A complex logistics and engineering challenge requiring precise coordination.
            </p>
            <div class="bg-emi-gray rounded-lg p-4 mb-4">
              <p class="text-sm text-gray-600 mb-1">Outcome</p>
              <p class="text-emi-gold font-bold">Completed safely, under budget, and on schedule</p>
              <p class="text-sm text-gray-600">with 3-4 trucks assembled simultaneously</p>
            </div>
          </div>

          <!-- Project 3: Workshop Design -->
          <div class="rounded-xl border border-gray-200 bg-white p-8 hover:shadow-lg transition-shadow">
            <div class="inline-block px-3 py-1 rounded-full bg-emi-gold/10 text-emi-gold text-xs font-semibold mb-4 uppercase tracking-wide">
              Facility Design
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-4">Workshop Design — Reliability Centre</h3>
            <p class="text-gray-700 mb-4">
              Design of drive-through refuelling facility, main workshop, and offices for a large mining company.
            </p>
            <div class="bg-emi-gray rounded-lg p-4 mb-4">
              <p class="text-sm text-gray-600 mb-1">Design Partner</p>
              <p class="text-gray-900 font-semibold">Pitt and Sherry (Launceston-based)</p>
            </div>
            <p class="text-gray-700 text-sm">
              The deliverable was a comprehensive "Reliability Centre" designed to optimise maintenance workflows and equipment throughput.
            </p>
          </div>

          <!-- Project 4: R2900G Strategy -->
          <div class="rounded-xl border border-gray-200 bg-white p-8 hover:shadow-lg transition-shadow">
            <div class="inline-block px-3 py-1 rounded-full bg-emi-gold/10 text-emi-gold text-xs font-semibold mb-4 uppercase tracking-wide">
              Strategy Consulting
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-4">Caterpillar R2900G Maintenance Strategy</h3>
            <p class="text-gray-700 mb-4">
              Strategy development for a Tier 1 Australian gold mining company managing a fleet of Cat R2900G LHD boggers in underground operations.
            </p>
            <div class="bg-emi-gray rounded-lg p-4">
              <p class="text-sm text-gray-600 mb-1">Collaboration</p>
              <p class="text-gray-900 font-semibold">Caterpillar Dealer & Caterpillar Underground</p>
              <p class="text-sm text-gray-600">Strategy development consulting for optimal fleet maintenance outcomes</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-16 sm:py-24 bg-emi-black text-white">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-2xl sm:text-3xl font-bold uppercase tracking-wide mb-4">
          Let's Discuss Your Project
        </h2>
        <p class="text-gray-300 mb-8 text-lg">
          Whether it's software implementation, strategy consulting, or facility design, we can help.
        </p>
        <a
          href="/contact"
          class="inline-flex items-center px-8 py-3 bg-emi-gold text-white font-semibold rounded-lg hover:bg-emi-gold-dark transition-colors"
        >
          Contact Us
        </a>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
