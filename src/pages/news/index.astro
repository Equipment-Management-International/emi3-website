---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { getClient } from '../../lib/contentful';
import type { NewsArticleSkeleton } from '../../lib/contentful-types';

const client = getClient();

let articles: any[] = [];
if (client) {
  try {
    const res = await client.getEntries<NewsArticleSkeleton>({
      content_type: 'newsArticle',
      order: ['-fields.date'],
    });
    articles = res.items;
  } catch (e) {
    console.error('Failed to fetch news articles:', e);
  }
}
---

<Layout title="News & Blogs — Equipment Management International">
  <Nav />
  <main class="pt-20">
    <section class="py-16 sm:py-24">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 uppercase tracking-wide mb-4">
          News & Blogs
        </h1>
        <p class="text-lg text-gray-600 mb-12 max-w-2xl">
          Latest updates, insights, and stories from Equipment Management International.
        </p>

        {articles.length > 0 ? (
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
            {articles.map((article) => {
              const { title, slug, date, excerpt, featuredImage, tags } = article.fields;
              const imgUrl = featuredImage?.fields?.file?.url
                ? `https:${featuredImage.fields.file.url}`
                : null;
              const formattedDate = new Date(date).toLocaleDateString('en-AU', {
                year: 'numeric',
                month: 'long',
                day: 'numeric',
              });

              return (
                <a
                  href={`/news/${slug}`}
                  class="group bg-white rounded-xl border border-gray-200 overflow-hidden hover:shadow-lg hover:border-emi-gold/50 transition-all duration-200"
                >
                  {imgUrl ? (
                    <img
                      src={imgUrl}
                      alt={title}
                      class="w-full h-48 object-cover"
                      loading="lazy"
                    />
                  ) : (
                    <div class="w-full h-48 bg-emi-gray flex items-center justify-center">
                      <svg class="w-12 h-12 text-gray-300" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 7.5h1.5m-1.5 3h1.5m-7.5 3h7.5m-7.5 3h7.5m3-9h3.375c.621 0 1.125.504 1.125 1.125V18a2.25 2.25 0 01-2.25 2.25M16.5 7.5V18a2.25 2.25 0 002.25 2.25M16.5 7.5V4.875c0-.621-.504-1.125-1.125-1.125H4.125C3.504 3.75 3 4.254 3 4.875V18a2.25 2.25 0 002.25 2.25h13.5" />
                      </svg>
                    </div>
                  )}
                  <div class="p-6">
                    <div class="flex items-center gap-3 mb-3">
                      <time class="text-xs text-gray-500">{formattedDate}</time>
                      {tags && tags.length > 0 && (
                        <span class="text-xs font-semibold text-emi-gold uppercase">{tags[0]}</span>
                      )}
                    </div>
                    <h2 class="text-lg font-bold text-gray-900 mb-2 group-hover:text-emi-gold-dark transition-colors">
                      {title}
                    </h2>
                    {excerpt && (
                      <p class="text-sm text-gray-600 leading-relaxed line-clamp-3">{excerpt}</p>
                    )}
                  </div>
                </a>
              );
            })}
          </div>
        ) : (
          <p class="text-gray-500">No articles yet. Check back soon!</p>
        )}
      </div>
    </section>
  </main>
  <Footer />
</Layout>
