---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import PageHero from '../../components/PageHero.astro';
import { getClient } from '../../lib/contentful';
import type { NewsArticleSkeleton } from '../../lib/contentful-types';

const client = getClient();

let articles: any[] = [];
if (client) {
  try {
    const res = await client.getEntries<NewsArticleSkeleton>({
      content_type: 'newsArticle',
      order: ['-fields.date'],
    });
    articles = res.items;
  } catch (e) {
    console.error('Failed to fetch news articles:', e);
  }
}

// Collect all unique tags across articles
const allTags = [...new Set(articles.flatMap((a) => a.fields.tags || []))].sort();
---

<Layout title="News & Blogs — Equipment Management International" description="Latest news, insights, and updates from Equipment Management International on mining maintenance software, industry trends, and operational improvement.">
  <Nav transparent />
  <main id="top">
    <PageHero
      compact
      image="/images/hero/news.jpg"
      title="News & Insights"
      subtitle="Latest updates, insights, and stories from Equipment Management International."
    />

    <!-- Articles grid -->
    <section class="py-16 sm:py-24 bg-base-200">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

        {/* Tag filter bar */}
        {allTags.length > 0 && (
          <div class="flex flex-wrap gap-2 mb-10" id="tag-filter">
            <button
              class="btn btn-sm btn-primary tag-btn"
              data-tag="all"
            >
              All
            </button>
            {allTags.map((tag) => (
              <button
                class="btn btn-sm btn-outline btn-primary tag-btn"
                data-tag={tag}
              >
                {tag}
              </button>
            ))}
          </div>
        )}

        {articles.length > 0 ? (
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8" id="articles-grid">
            {articles.map((article) => {
              const { title, slug, date, excerpt, featuredImage, tags } = article.fields;
              const imgUrl = featuredImage?.fields?.file?.url
                ? `https:${featuredImage.fields.file.url}`
                : null;
              const formattedDate = new Date(date).toLocaleDateString('en-AU', {
                year: 'numeric',
                month: 'long',
                day: 'numeric',
              });
              const tagList = (tags || []).join(',');

              return (
                <a
                  href={`/news/${slug}`}
                  class="card bg-base-100 shadow-sm hover:shadow-lg border border-base-300 hover:border-primary/50 transition-all duration-200 group article-card"
                  data-tags={tagList}
                >
                  <figure class="aspect-[16/10] overflow-hidden">
                    {imgUrl ? (
                      <img
                        src={imgUrl}
                        alt={title}
                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                        loading="lazy"
                      />
                    ) : (
                      <div class="w-full h-full bg-base-200 flex items-center justify-center">
                        <svg class="w-16 h-16 text-base-content/20" fill="none" viewBox="0 0 24 24" stroke-width="0.75" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M12 7.5h1.5m-1.5 3h1.5m-7.5 3h7.5m-7.5 3h7.5m3-9h3.375c.621 0 1.125.504 1.125 1.125V18a2.25 2.25 0 01-2.25 2.25M16.5 7.5V18a2.25 2.25 0 002.25 2.25M16.5 7.5V4.875c0-.621-.504-1.125-1.125-1.125H4.125C3.504 3.75 3 4.254 3 4.875V18a2.25 2.25 0 002.25 2.25h13.5" />
                        </svg>
                      </div>
                    )}
                  </figure>
                  <div class="card-body">
                    <div class="flex items-center gap-2 flex-wrap mb-1">
                      <time class="text-sm text-base-content/60">{formattedDate}</time>
                      {tags && tags.map((tag: string) => (
                        <span class="badge badge-primary badge-outline badge-sm">{tag}</span>
                      ))}
                    </div>
                    <h2 class="section-subheading group-hover:text-primary transition-colors">
                      {title}
                    </h2>
                    {excerpt && (
                      <p class="prose-body line-clamp-3">{excerpt}</p>
                    )}
                  </div>
                </a>
              );
            })}
          </div>
        ) : (
          <div class="text-center py-16">
            <svg class="w-16 h-16 text-base-content/20 mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke-width="0.75" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 7.5h1.5m-1.5 3h1.5m-7.5 3h7.5m-7.5 3h7.5m3-9h3.375c.621 0 1.125.504 1.125 1.125V18a2.25 2.25 0 01-2.25 2.25M16.5 7.5V18a2.25 2.25 0 002.25 2.25M16.5 7.5V4.875c0-.621-.504-1.125-1.125-1.125H4.125C3.504 3.75 3 4.254 3 4.875V18a2.25 2.25 0 002.25 2.25h13.5" />
            </svg>
            <p class="prose-body">No articles yet. Check back soon!</p>
          </div>
        )}

        {/* Empty state for filtered results */}
        <div id="no-results" class="text-center py-16 hidden">
          <p class="prose-body">No articles found for this tag.</p>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<script>
  const buttons = document.querySelectorAll('.tag-btn');
  const cards = document.querySelectorAll('.article-card');
  const noResults = document.getElementById('no-results');

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const tag = (btn as HTMLElement).dataset.tag;

      // Update button styles
      buttons.forEach((b) => {
        b.classList.remove('btn-primary');
        b.classList.add('btn-outline');
      });
      btn.classList.remove('btn-outline');
      btn.classList.add('btn-primary');

      // Filter cards
      let visibleCount = 0;
      cards.forEach((card) => {
        const cardTags = (card as HTMLElement).dataset.tags || '';
        const matches = tag === 'all' || cardTags.split(',').includes(tag!);
        (card as HTMLElement).style.display = matches ? '' : 'none';
        if (matches) visibleCount++;
      });

      // Show/hide empty state
      if (noResults) {
        noResults.classList.toggle('hidden', visibleCount > 0);
      }
    });
  });
</script>
