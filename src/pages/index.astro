---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import HeroSection from '../components/HeroSection.astro';
import ValueProp from '../components/ValueProp.astro';
import Specialisations from '../components/Specialisations.astro';
import ProductGrid from '../components/ProductGrid.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import CTASection from '../components/CTASection.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Equipment Management International — Complex Digital Work Instructions, Shared Simply">
  <Nav transparent />
  <main id="top">
    <HeroSection />
    <ValueProp />

    <!-- YouTube Video -->
    <section class="py-16 sm:py-24 bg-emi-gray">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="aspect-video rounded-xl overflow-hidden shadow-lg">
          <iframe
            src="https://www.youtube.com/embed/xxhrqxrrCCI"
            title="Equipment Management International"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            class="w-full h-full"
            loading="lazy"
          ></iframe>
        </div>
      </div>
    </section>

    <Specialisations />
    <ProductGrid />
    <ProcessSteps />
    <CTASection />
  </main>
  <Footer />
</Layout>
