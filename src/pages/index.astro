---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import HeroSection from '../components/HeroSection.astro';
import ValueProp from '../components/ValueProp.astro';
import Specialisations from '../components/Specialisations.astro';
import ProductGrid from '../components/ProductGrid.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import CTASection from '../components/CTASection.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Equipment Management International — Complex Digital Work Instructions, Shared Simply" description="Equipment Management International provides maintenance software solutions for Tier 1 and 2 mining operations across Australia. Est. 2005.">
  <Nav transparent />
  <main id="top">
    <HeroSection />
    <ValueProp />

    <!-- YouTube Video -->
    <section class="py-16 sm:py-24 bg-base-200">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-8">
          <h2 class="section-heading mb-3">See Our Platform in Action</h2>
          <p class="prose-body">How our software transforms maintenance operations on mining sites</p>
        </div>
        <div class="aspect-video rounded-xl overflow-hidden shadow-xl">
          <iframe
            src="https://www.youtube.com/embed/xxhrqxrrCCI"
            title="Equipment Management International — Platform Overview"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            class="w-full h-full"
            loading="lazy"
          ></iframe>
        </div>
      </div>
    </section>

    <Specialisations />
    <ProductGrid />
    <ProcessSteps />
    <CTASection />
  </main>
  <Footer />
</Layout>
