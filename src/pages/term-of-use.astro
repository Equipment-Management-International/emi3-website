---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Terms of Use — Equipment Management International">
  <Nav />
  <main class="pt-20">
    <!-- Hero -->
    <section class="bg-emi-charcoal text-white py-16 sm:py-20 scroll-mt-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h1 class="text-3xl sm:text-4xl font-bold uppercase tracking-wide">
          Terms of Use
        </h1>
        <p class="text-gray-400 mt-2">Effective Date: May 1, 2023 — Applies to EMI3.io and applications within</p>
      </div>
    </section>

    <!-- Content -->
    <section class="py-16 sm:py-24 bg-white">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="prose prose-lg max-w-none space-y-8 text-gray-700">
          <div>
            <h2 class="text-xl font-bold text-gray-900 mb-3">1. Subscription License</h2>
            <p>
              EMI3 and the applications within are licensed on a concurrent or a total user subscription basis. This means that you may use the application with the number of concurrent or total users specified in your subscription plan. Your subscription is non-transferable and non-refundable. You may not share your subscription with any third party, including but not limited to other companies or individuals. If you require additional concurrent or total users, you must upgrade your subscription plan with Equipment Management International P/L.
