---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Magnom Filtration — Equipment Management International">
  <Nav />
  <main class="pt-20">
    <!-- Hero -->
    <section class="bg-emi-charcoal text-white py-16 sm:py-24 scroll-mt-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold uppercase tracking-wide mb-6">
          Magnom Filtration
        </h1>
        <p class="text-xl text-gray-300 max-w-3xl mx-auto">
          Equipment Management International P/L is the national distributor for Magnom
        </p>
      </div>
    </section>

    <!-- Product Description -->
    <section class="py-16 sm:py-24 bg-white">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 uppercase tracking-wide mb-8">
          Innovative Filtration Technology
        </h2>
        <p class="text-xl text-gray-900 font-semibold mb-6">
          Magnom filtration removes ferrous particles down to 1 micron in size, is cleanable and does not restrict flow.
        </p>
        <p class="text-lg text-gray-700 mb-6">
          These are just some of the core features and benefits of this innovative filtration technology.
        </p>
        <p class="text-gray-700">
          Equipment Management International P/L is the Australian distributor of Magnom Filter Systems.
        </p>
      </div>
    </section>

    <!-- Key Features -->
    <section class="py-16 sm:py-24 bg-emi-gray">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 uppercase tracking-wide text-center mb-12">
          Core Features & Benefits
        </h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8 max-w-5xl mx-auto">
          <div class="rounded-xl border border-gray-200 bg-white p-8 text-center hover:shadow-lg transition-shadow">
            <div class="w-16 h-16 rounded-full bg-emi-gold/10 flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-emi-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"/></svg>
            </div>
            <h3 class="font-bold text-gray-900 mb-2">Sub-Micron Filtration</h3>
            <p class="text-gray-600 text-sm">Removes ferrous particles down to 1 micron in size</p>
          </div>
          <div class="rounded-xl border border-gray-200 bg-white p-8 text-center hover:shadow-lg transition-shadow">
            <div class="w-16 h-16 rounded-full bg-emi-gold/10 flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-emi-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
            </div>
            <h3 class="font-bold text-gray-900 mb-2">Cleanable & Reusable</h3>
            <p class="text-gray-600 text-sm">Easily cleaned and maintained for long-term use</p>
          </div>
          <div class="rounded-xl border border-gray-200 bg-white p-8 text-center hover:shadow-lg transition-shadow">
            <div class="w-16 h-16 rounded-full bg-emi-gold/10 flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-emi-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
            </div>
            <h3 class="font-bold text-gray-900 mb-2">No Flow Restriction</h3>
            <p class="text-gray-600 text-sm">Does not restrict fluid flow through the system</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Partner Section -->
    <section class="py-16 sm:py-24 bg-white">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 uppercase tracking-wide mb-8">
          Become a Partner
        </h2>
        <p class="text-lg text-gray-700 mb-8">
          Interested in becoming a Magnom reseller in your region? We're looking for partners across Australia to help distribute this innovative filtration technology.
        </p>
        <a
          href="/contact"
          class="inline-flex items-center px-8 py-3 bg-emi-gold text-white font-semibold rounded-lg hover:bg-emi-gold-dark transition-colors"
        >
          Contact Us to Learn More
        </a>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-16 sm:py-24 bg-emi-black text-white">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-2xl sm:text-3xl font-bold uppercase tracking-wide mb-4">
          Interested in Magnom Filtration?
        </h2>
        <p class="text-gray-300 mb-8 text-lg">
          Get in touch to learn more about Magnom filter systems and how they can benefit your operation.
        </p>
        <a
          href="/contact"
          class="inline-flex items-center px-8 py-3 bg-emi-gold text-white font-semibold rounded-lg hover:bg-emi-gold-dark transition-colors"
        >
          Contact Us
        </a>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
