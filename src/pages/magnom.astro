---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';
import CTABanner from '../components/CTABanner.astro';
---

<Layout title="Magnom Filtration — Equipment Management International" description="EMI is the Australian distributor for Magnom filtration systems. Removes ferrous particles down to 1 micron, cleanable, and does not restrict flow.">
  <Nav />
  <main id="top" class="pt-20">
    <PageHero
      title="Magnom Filtration"
      align="center"
    >
      <p class="text-lg text-white/80">
        Equipment Management International P/L is the national distributor for
        <a href="https://www.magnom.com" target="_blank" rel="noopener noreferrer" class="text-primary hover:text-primary/80 underline underline-offset-2">Magnom</a>
      </p>
    </PageHero>

    <!-- Product Description -->
    <section class="py-16 sm:py-24 bg-base-100">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="section-heading mb-8">
          Innovative Filtration Technology
        </h2>
        <p class="text-xl font-semibold mb-6">
          Magnom filtration removes ferrous particles down to 1 micron in size, is cleanable and does not restrict flow.
        </p>
        <p class="prose-body mb-6">
          These are just some of the core features and benefits of this innovative filtration technology.
        </p>
        <p class="prose-body">
          Equipment Management International P/L is the Australian distributor of
          <a href="https://www.magnom.com" target="_blank" rel="noopener noreferrer" class="text-primary hover:text-primary/80 font-medium underline underline-offset-2">Magnom Filter Systems</a>.
        </p>
      </div>
    </section>

    <!-- Key Features -->
    <section class="py-16 sm:py-24 bg-base-200">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="section-heading text-center mb-12">
          Core Features & Benefits
        </h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8 max-w-5xl mx-auto">
          <div class="card bg-base-100 shadow-md hover:shadow-xl transition-shadow">
            <div class="card-body items-center text-center">
              <div class="w-16 h-16 rounded-full bg-primary/10 flex items-center justify-center">
                <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"/></svg>
              </div>
              <h3 class="section-subheading mt-2">Sub-Micron Filtration</h3>
              <p class="text-base">Removes ferrous particles down to 1 micron in size</p>
            </div>
          </div>
          <div class="card bg-base-100 shadow-md hover:shadow-xl transition-shadow">
            <div class="card-body items-center text-center">
              <div class="w-16 h-16 rounded-full bg-primary/10 flex items-center justify-center">
                <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
              </div>
              <h3 class="section-subheading mt-2">Cleanable & Reusable</h3>
              <p class="text-base">Easily cleaned and maintained for long-term use</p>
            </div>
          </div>
          <div class="card bg-base-100 shadow-md hover:shadow-xl transition-shadow">
            <div class="card-body items-center text-center">
              <div class="w-16 h-16 rounded-full bg-primary/10 flex items-center justify-center">
                <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
              </div>
              <h3 class="section-subheading mt-2">No Flow Restriction</h3>
              <p class="text-base">Does not restrict fluid flow through the system</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Partner Section -->
    <section class="py-16 sm:py-24 bg-base-100">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="section-heading mb-8">
          Become a Partner
        </h2>
        <p class="prose-body mb-8">
          Interested in becoming a Magnom reseller in your region? We're looking for partners across Australia to help distribute this innovative filtration technology.
        </p>
        <a href="/contact" class="btn btn-primary btn-lg">
          Contact Us to Learn More
        </a>
      </div>
    </section>

    <!-- CTA -->
    <CTABanner
      heading="Interested in Magnom Filtration?"
      subtitle="Get in touch to learn more about Magnom filter systems and how they can benefit your operation."
      primaryLabel="Contact Us"
      primaryHref="/contact"
    />
  </main>
  <Footer />
</Layout>
