---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';
import QuoteBlock from '../components/QuoteBlock.astro';
import CTABanner from '../components/CTABanner.astro';
---

<Layout title="Take Action — Equipment Management International" description="Book a 5-7 day on-site review to uncover maintenance inefficiencies. EMI delivers a detailed impact report with actionable solutions for mining operations.">
  <Nav />
  <main id="top" class="pt-20">
    <PageHero
      title="Take Action"
      align="center"
    >
      <QuoteBlock attribution="Zig Ziglar" variant="large">
        <span class="text-white">"You don't have to be great to start, you have to start to be great"</span>
      </QuoteBlock>
    </PageHero>

    <!-- Site Review Description -->
    <section class="py-16 sm:py-24 bg-base-100">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="section-heading mb-8">
          Site Review
        </h2>
        <div class="space-y-6 prose-body">
          <p>
            Many organisations seek cost reduction and efficiency improvements within maintenance departments. We help clients understand how their maintenance team operates, identify the root causes of problems, and pinpoint critical focus areas.
          </p>
          <p>
            Managers often find themselves consumed by day-to-day operations rather than strategic planning, missing visibility into actual team performance and underlying issues.
          </p>
        </div>
        <div class="mt-8">
          <QuoteBlock>
            Our approach is direct, fact based and the findings can be confronting.
          </QuoteBlock>
        </div>
      </div>
    </section>

    <!-- Methodology -->
    <section class="py-16 sm:py-24 bg-base-200">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="section-heading mb-4">
          How We Do It
        </h2>
        <p class="text-primary font-semibold text-lg mb-8">
          Approximately 5-7 days onsite
        </p>

        <div class="grid sm:grid-cols-2 gap-8 mb-10">
          <div>
            <h3 class="section-subheading mb-4">Activities Include:</h3>
            <ul class="space-y-3">
              {[
                'Study maintenance operation methods and fundamentals',
                'Conduct time and motion studies',
                'Interview key personnel',
                'Review facilities, systems, and procedures',
              ].map((activity) => (
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-primary flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                  <span class="text-base">{activity}</span>
                </li>
              ))}
            </ul>
          </div>
          <div>
            <h3 class="section-subheading mb-4">Deliverables:</h3>
            <ul class="space-y-3">
              {[
                'Presentation of findings before departure',
                'Comprehensive report with implementation solutions',
              ].map((deliverable) => (
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-primary flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                  <span class="text-base">{deliverable}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- 15 Focus Areas -->
    <section class="py-16 sm:py-24 bg-base-100">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="section-heading text-center mb-12">
          Focus Areas
        </h2>
        <div class="grid sm:grid-cols-3 lg:grid-cols-5 gap-4 max-w-6xl mx-auto">
          {[
            'Critical Safety Concerns',
            'Supply Processes',
            'Consistency & Repeatability',
            'Methods & Practices',
            'Supervisor Interactions',
            'Tooling & Infrastructure',
            'Systems & Processes',
            'Maintenance Strategy',
            'Life Cycle Strategy',
            'Contractor Performance',
            'Culture & Frustrations',
            'Asset Condition',
            'Operational Practices',
            'Environmental Constraints',
            'Maintenance Management Maturity',
          ].map((area) => (
            <div class="card bg-base-200 hover:border-primary border border-base-300 transition-colors">
              <div class="card-body p-4 items-center text-center">
                <p class="text-base font-semibold">{area}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <CTABanner
      heading="Ready to Take That First Step?"
      subtitle="Contact us today to discuss a Site Review and start the journey to better maintenance outcomes."
      primaryLabel="Contact Us"
      primaryHref="/contact"
    />
  </main>
  <Footer />
</Layout>
