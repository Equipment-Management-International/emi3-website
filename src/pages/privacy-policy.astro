---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Privacy Policy — Equipment Management International" description="Privacy policy for Equipment Management International. Learn how we collect, use, and protect your personal information under Australian Privacy Principles.">
  <Nav />
  <main id="top" class="pt-20">
    <!-- Hero -->
    <section class="bg-neutral text-neutral-content py-16 sm:py-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h1 class="text-3xl sm:text-4xl font-bold">
          Privacy Policy
        </h1>
        <p class="text-neutral-content/70 mt-2 text-base">Effective Date: November 13, 2023</p>
      </div>
    </section>

    <!-- Content -->
    <section class="py-16 sm:py-24 bg-base-100">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="card bg-base-100 shadow-sm border border-base-300">
          <div class="card-body space-y-8">
            <div>
              <h2 class="section-subheading mb-3">Introduction</h2>
              <p class="prose-body">
                Equipment Management International P/L is committed to protecting the personal information collected through our website. We follow the Australian Privacy Principles (APPs) in the handling of all personal information.
              </p>
            </div>

            <div>
              <h2 class="section-subheading mb-3">APP 1 — Website Usage Data</h2>
              <p class="prose-body">
                Our site automatically gathers statistics including server addresses, domain names, accessed pages, referral sources, and browser types. We do not attempt to identify you or your browsing activities.
              </p>
            </div>

            <div>
              <h2 class="section-subheading mb-3">APP 3 — Form-Based Collection</h2>
              <p class="prose-body">
                Personal data is collected only through feedback forms for service provision. We will only collect information directly from you and will provide explanations on forms about data usage purposes.
              </p>
            </div>

            <div>
              <h2 class="section-subheading mb-3">APP 6 — Use & Disclosure</h2>
              <p class="prose-body">
                Email addresses are recorded only when you contact us and are used solely for that stated purpose. Please note there are inherent risks in online transmission of information.
              </p>
            </div>

            <div>
              <h2 class="section-subheading mb-3">APP 10 — Data Quality</h2>
              <p class="prose-body">
                Information remains accurate and current, used only for intended purposes unless you've subscribed or joined as a member.
              </p>
            </div>

            <div>
              <h2 class="section-subheading mb-3">APP 11 — Security</h2>
              <p class="prose-body">
                We use encryption and security certificates to protect your information. We permanently de-identify information after service completion, retaining only activity records.
              </p>
            </div>

            <div>
              <h2 class="section-subheading mb-3">APP 12 — Access Rights</h2>
              <p class="prose-body">
                Upon request, you can view the information we hold about you and request alterations to ensure accuracy.
              </p>
            </div>

            <div>
              <h2 class="section-subheading mb-3">Additional Protections</h2>
              <ul class="prose-body list-disc list-inside space-y-2">
                <li>Sensitive information collection requires explicit consent</li>
                <li>No overseas transfers occur without consent</li>
                <li>Government identifiers aren't used unless acting as government agents</li>
              </ul>
            </div>

            <div class="border-t border-base-300 pt-8">
              <h2 class="section-subheading mb-3">Contact</h2>
              <p class="prose-body">
                If you have any complaints or queries regarding our privacy practices, please <a href="/contact" class="link link-primary">contact us</a>.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
