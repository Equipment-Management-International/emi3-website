---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Maintenance Software Suite — Equipment Management International" description="Purpose-built maintenance software for mining. ZoneMaintenance and RouteMaintenance digitise PM services, reducing turnaround times and eliminating paper.">
  <Nav />
  <main id="top" class="pt-20">
    <!-- Hero with background image -->
    <section class="relative min-h-[50vh] flex items-center overflow-hidden">
      <div class="absolute inset-0">
        <img
          src="/images/hero/software.jpg"
          alt=""
          class="absolute inset-0 w-full h-full object-cover"
        />
        <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-black/50 to-black/70"></div>
      </div>
      <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center py-16 sm:py-24 w-full">
        <h1 class="text-3xl sm:text-4xl font-bold text-white mb-6 hero-text-shadow">
          Maintenance Software Suite
        </h1>
        <p class="text-lg text-white/90 max-w-3xl mx-auto hero-text-shadow">
          Specialised maintenance software that's designed and built by tradesmen who've been on the tools and across management
        </p>
      </div>
    </section>

    <!-- Opening -->
    <section class="py-16 sm:py-24 bg-base-100">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <p class="prose-body">
          Let's be honest. There are plenty of common issues with fixed and mobile maintenance that lead to wasted time and effort. Our maintenance software suite addresses these problems head-on with purpose-built solutions.
        </p>
      </div>
    </section>

    <!-- Key Features -->
    <section class="py-16 sm:py-24 bg-base-200">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="section-heading text-center mb-12">
          Key Features
        </h2>
        <div class="grid sm:grid-cols-2 gap-6 max-w-4xl mx-auto">
          {[
            'Converts paper PM service sheets to mobility-based software for paperless workflows',
            'Electronically records defects, findings, oil and water leaks',
            'Increases workforce autonomy, accountability, and precision',
            'Incorporates sensory-based data collection for asset health monitoring',
            'Delivers real-time feedback and analytics',
            'Supports job status visibility across teams',
            'Improves asset condition awareness to prevent catastrophic failures',
            'Delivers measurable improvements in efficiency, uptime, and compliance',
          ].map((feature) => (
            <div class="flex items-start gap-3">
              <svg class="w-6 h-6 text-primary flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              <p class="text-base">{feature}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Product Cards -->
    <section class="py-16 sm:py-24 bg-base-100">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="section-heading text-center mb-12">
          Our Maintenance Products
        </h2>

        <div class="grid md:grid-cols-2 gap-8 max-w-5xl mx-auto">
          <!-- ZoneMaintenance -->
          <div class="card bg-base-100 shadow-md hover:shadow-xl transition-shadow">
            <figure class="px-8 pt-8">
              <img
                src="/images/products/zone-maintenance-logo.jpg"
                alt="ZoneMaintenance logo"
                class="h-16 object-contain"
              />
            </figure>
            <div class="card-body">
              <h3 class="card-title">ZoneMaintenance</h3>
              <div class="badge badge-primary badge-outline">Mobile Equipment Maintenance</div>
              <p class="prose-body mt-3">
                Streamline your maintenance processes for mobile equipment when safe, high quality, and efficient turnaround is essential. ZoneMaintenance offers a simple and repeatable method of servicing mobile mining equipment using a defined process.
              </p>
              <p class="section-subheading text-base-content/70 mt-4 !text-base">Designed for:</p>
              <ul class="space-y-2 mt-2">
                <li class="flex items-center gap-2 text-base">
                  <svg class="w-5 h-5 text-primary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                  PM servicing to mobile equipment
                </li>
                <li class="flex items-center gap-2 text-base">
                  <svg class="w-5 h-5 text-primary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                  Component removal and replacement
                </li>
                <li class="flex items-center gap-2 text-base">
                  <svg class="w-5 h-5 text-primary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                  Component strip down and assembly
                </li>
              </ul>
              <div class="card-actions mt-6">
                <a href="/zonemaintenance" class="btn btn-primary">
                  Learn More
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                </a>
              </div>
            </div>
          </div>

          <!-- RouteMaintenance -->
          <div class="card bg-base-100 shadow-md hover:shadow-xl transition-shadow">
            <figure class="px-8 pt-8">
              <img
                src="/images/products/route-maintenance-logo.jpg"
                alt="RouteMaintenance logo"
                class="h-16 object-contain"
              />
            </figure>
            <div class="card-body">
              <h3 class="card-title">RouteMaintenance</h3>
              <div class="badge badge-primary badge-outline">Fixed Plant Maintenance</div>
              <p class="prose-body mt-3">
                Focus on efficient, clearly defined, and repeatable methods for carrying out periodic inspections of fixed plant facilities. Ideal for teams managing paper-based work orders with inconsistent workforce experience levels.
              </p>
              <p class="section-subheading text-base-content/70 mt-4 !text-base">Designed for:</p>
              <ul class="space-y-2 mt-2">
                <li class="flex items-center gap-2 text-base">
                  <svg class="w-5 h-5 text-primary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                  PM servicing and inspections
                </li>
                <li class="flex items-center gap-2 text-base">
                  <svg class="w-5 h-5 text-primary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                  Critical asset compliance inspections
                </li>
                <li class="flex items-center gap-2 text-base">
                  <svg class="w-5 h-5 text-primary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                  Hazardous environment inspections
                </li>
              </ul>
              <div class="card-actions mt-6">
                <a href="/routemaintenance" class="btn btn-primary">
                  Learn More
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Footer Note -->
    <section class="py-12 bg-neutral text-neutral-content">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <p class="text-neutral-content/80 text-base">
          All our software applications are owned by EMI and developed in-house in Australia.
        </p>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
