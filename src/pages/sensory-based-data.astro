---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';
import CTABanner from '../components/CTABanner.astro';
---

<Layout title="Sensory Based Data — Equipment Management International" description="Combine what technicians see, hear, smell, and touch with sensor data for a complete asset health picture. The missing link in mining maintenance.">
  <Nav transparent />
  <main id="top">
    <PageHero
      title="Sensory Based Data"
      subtitle="The Missing Link"
      image="/images/hero/sensory-data.jpg"
      align="center"
    />

    <!-- Evolution of Maintenance -->
    <section class="py-16 sm:py-24 bg-base-100">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="section-heading mb-8">
          The Evolution of Maintenance Practices
        </h2>
        <div class="space-y-6 prose-body">
          <p>
            Decades ago, mining maintenance was reactive — fixing equipment only after it broke. The introduction of preventative maintenance and sensor technologies improved productivity significantly. However, gaps in defect reporting persist.
          </p>
          <p>
            Paper-based service sheets and defect notes often get lost in filing cabinets or go unrecorded in the CMMS. Missed defect reporting occurs when field technicians lack time or tools to properly document what they find.
          </p>
        </div>
      </div>
    </section>

    <!-- The Missing Link -->
    <section class="py-16 sm:py-24 bg-neutral text-neutral-content">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="section-heading text-neutral-content mb-8">
          Bridging the Gap: The Missing Link
        </h2>
        <p class="text-lg text-neutral-content/80 max-w-3xl mx-auto">
          A system integrating <span class="text-primary font-semibold">sensory based data</span> — what technicians see, hear, smell, and touch — with the sensor-based data collected automatically. This combination creates a comprehensive view of asset health that neither data source can provide alone.
        </p>
      </div>
    </section>

    <!-- Why Sensory Data Matters -->
    <section class="py-16 sm:py-24 bg-base-100">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="section-heading text-center mb-4">
          Why Sensory-Based Data Matters
        </h2>
        <p class="prose-body text-center max-w-3xl mx-auto mb-12">
          Field technicians detect failure signs that sensors cannot, including:
        </p>
        <div class="grid sm:grid-cols-3 gap-8 max-w-4xl mx-auto">
          <div class="card bg-base-100 shadow-md hover:shadow-xl transition-shadow">
            <div class="card-body items-center text-center">
              <div class="w-16 h-16 rounded-full bg-primary/10 flex items-center justify-center">
                <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.536 8.464a5 5 0 010 7.072m2.828-9.9a9 9 0 010 12.728M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z"/></svg>
              </div>
              <h3 class="section-subheading mt-2">Hear</h3>
              <p class="text-base">Unusual noises indicating bearing wear or component failure</p>
            </div>
          </div>
          <div class="card bg-base-100 shadow-md hover:shadow-xl transition-shadow">
            <div class="card-body items-center text-center">
              <div class="w-16 h-16 rounded-full bg-primary/10 flex items-center justify-center">
                <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
              </div>
              <h3 class="section-subheading mt-2">Feel</h3>
              <p class="text-base">Subtle vibrations pointing to misalignment or imbalance</p>
            </div>
          </div>
          <div class="card bg-base-100 shadow-md hover:shadow-xl transition-shadow">
            <div class="card-body items-center text-center">
              <div class="w-16 h-16 rounded-full bg-primary/10 flex items-center justify-center">
                <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.879 16.121A3 3 0 1012.015 11L11 14H9c0 .768.293 1.536.879 2.121z"/></svg>
              </div>
              <h3 class="section-subheading mt-2">Smell</h3>
              <p class="text-base">Odours signalling overheating or contamination</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 3-Step Digital Integration -->
    <section class="py-16 sm:py-24 bg-base-200">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="section-heading text-center mb-12">
          The Solution: Digital Tools for Real-Time Integration
        </h2>
        <div class="grid md:grid-cols-3 gap-8 max-w-5xl mx-auto">
          <div class="relative">
            <div class="w-12 h-12 rounded-full bg-primary text-primary-content flex items-center justify-center font-bold text-xl mb-4">1</div>
            <h3 class="section-subheading mb-3">In-Field Data Collection</h3>
            <p class="prose-body">
              Technicians use mobile devices to record observations during inspections — what they see, hear, smell, and touch.
            </p>
          </div>
          <div class="relative">
            <div class="w-12 h-12 rounded-full bg-primary text-primary-content flex items-center justify-center font-bold text-xl mb-4">2</div>
            <h3 class="section-subheading mb-3">Integrated Defect Reporting</h3>
            <p class="prose-body">
              Observations are automatically logged into the CMMS, eliminating paper trails and lost information.
            </p>
          </div>
          <div class="relative">
            <div class="w-12 h-12 rounded-full bg-primary text-primary-content flex items-center justify-center font-bold text-xl mb-4">3</div>
            <h3 class="section-subheading mb-3">Correlated Data Analysis</h3>
            <p class="prose-body">
              Combining sensory and sensor data provides a comprehensive view of asset health for better decision-making.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Benefits -->
    <section class="py-16 sm:py-24 bg-base-100">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="section-heading text-center mb-12">
          The Benefits of a Unified System
        </h2>
        <div class="grid sm:grid-cols-3 gap-8 max-w-4xl mx-auto">
          <div class="card bg-base-100 shadow-md">
            <div class="card-body items-center text-center">
              <div class="w-16 h-16 rounded-full bg-primary/10 flex items-center justify-center">
                <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
              </div>
              <h3 class="section-subheading mt-2">Identify Hidden Defects</h3>
              <p class="text-base">Before they escalate into costly failures</p>
            </div>
          </div>
          <div class="card bg-base-100 shadow-md">
            <div class="card-body items-center text-center">
              <div class="w-16 h-16 rounded-full bg-primary/10 flex items-center justify-center">
                <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
              </div>
              <h3 class="section-subheading mt-2">Improve Decision-Making</h3>
              <p class="text-base">With a complete asset health picture</p>
            </div>
          </div>
          <div class="card bg-base-100 shadow-md">
            <div class="card-body items-center text-center">
              <div class="w-16 h-16 rounded-full bg-primary/10 flex items-center justify-center">
                <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
              </div>
              <h3 class="section-subheading mt-2">Reduce Downtime & Costs</h3>
              <p class="text-base">Through proactive maintenance strategies</p>
            </div>
          </div>
        </div>
        <p class="prose-body text-center max-w-3xl mx-auto mt-10">
          When all these pieces of information are aligned with other sources, the picture is full and clear, which means more effective decisions can be made.
        </p>
      </div>
    </section>

    <!-- Proven Tools -->
    <section class="py-16 sm:py-24 bg-base-200">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="section-heading text-center mb-12">
          Proven Tools for the Mining Industry
        </h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 max-w-4xl mx-auto">
          {[
            { name: 'ZoneMaintenance', desc: 'Mobile equipment maintenance', href: '/zonemaintenance' },
            { name: 'RouteMaintenance', desc: 'Fixed plant inspections', href: '/routemaintenance' },
            { name: 'ComponentStatus', desc: 'Component rebuilds', href: '/componentstatus' },
            { name: 'SafetyStatus', desc: 'Safety audits & inspections', href: '/safetystatus' },
            { name: 'EnviroStatus', desc: 'Environmental assessments', href: '/contact' },
          ].map((product) => (
            <a href={product.href} class="card bg-base-100 shadow-md hover:shadow-xl transition-shadow">
              <div class="card-body">
                <h3 class="card-title text-base">{product.name}</h3>
                <p class="text-base text-base-content/70">{product.desc}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <CTABanner
      heading="Take the Next Step"
      subtitle="Stay ahead in today's competitive mining landscape. It's essential to adopt a digitalisation strategy that combines sensor and sensory data."
      primaryLabel="Contact Us Today"
      primaryHref="/contact"
      secondaryLabel="Take Action"
      secondaryHref="/take-action"
    />
  </main>
  <Footer />
</Layout>
