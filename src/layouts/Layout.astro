---
interface Props {
  title: string;
  description?: string;
}

const gaId = import.meta.env.PUBLIC_GA_ID;
const {
  title,
  description = 'Complex digital work instructions, shared simply. Equipment Management International provides maintenance software for mining operations.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site).href} />

    <!-- Favicon -->
    <link rel="icon" href="/favicon.ico" sizes="any" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>

    <!-- Global CSS -->
    <style is:global>
      @import '../styles/global.css';
    </style>
  </head>
  <body class="min-h-screen bg-white text-gray-900">
    <slot />
  </body>
</html>
