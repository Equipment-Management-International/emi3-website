---
---

<section class="relative min-h-[85vh] flex items-center overflow-hidden">
  <!-- Background -->
  <div class="absolute inset-0">
    <img
      src="/images/hero/mining-equipment.jpg"
      alt=""
      class="absolute inset-0 w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-black/55"></div>
  </div>

  <div class="relative z-20 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full py-20 text-center">
    <div class="max-w-3xl mx-auto">
      <!-- Logo -->
      <div class="mb-10">
        <div class="glass-panel-light rounded-lg px-4 py-2 inline-block">
          <img
            src="/images/emi-logo.jpeg"
            alt="Equipment Management International"
            class="h-9 sm:h-12 w-auto"
          />
        </div>
      </div>

      <!-- Heading in glass panel for readability -->
      <div class="glass-panel rounded-2xl px-8 py-8 sm:px-10 sm:py-10 mb-8">
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white leading-tight mb-4">
          Complex Digital Work Instructions, Shared Simply
        </h1>
        <p class="text-lg text-white/80 max-w-2xl mx-auto leading-relaxed">
          Maintenance software for mid to large mining operations. Reducing PM service times, increasing fleet reliability, and eliminating paper.
        </p>
      </div>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/take-action" class="btn btn-primary btn-lg">
          Get Started
        </a>
        <a href="/software" class="btn btn-lg glass-panel-light text-white hover:bg-white/20 border-0">
          Explore Software
        </a>
      </div>
    </div>
  </div>

  <!-- Sensory data link — pinned to bottom -->
  <div class="absolute bottom-6 left-0 right-0 z-20 text-center">
    <a href="/sensory-based-data" class="glass-panel-light rounded-full px-5 py-2 inline-flex items-center gap-2 text-sm text-white/80 hover:text-primary hover:bg-white/15 transition-colors">
      Sensory Based Data — The Missing Link
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
    </a>
  </div>
</section>
