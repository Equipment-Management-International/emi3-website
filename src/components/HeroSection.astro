---
---

<section class="relative min-h-[80vh] flex items-center justify-center overflow-hidden bg-emi-black">
  <!-- Background image with dark overlay (matches current site) -->
  <div class="absolute inset-0">
    <img
      src="/images/hero/mining-equipment.jpg"
      alt=""
      class="absolute inset-0 w-full h-full object-cover sepia brightness-75"
    />
    <div class="absolute inset-0 bg-black/30"></div>
  </div>

  <!-- Content -->
  <div class="relative z-20 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <!-- EMI Logo -->
    <div class="flex justify-center mb-8">
      <div class="bg-white/90 rounded-xl px-6 py-3">
        <img
          src="/images/emi-logo.jpeg"
          alt="Equipment Management International"
          class="h-12 sm:h-16 w-auto"
        />
      </div>
    </div>

    <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white leading-tight mb-6 uppercase tracking-wide">
      Complex Digital Work Instructions, Shared Simply
    </h1>
    <p class="text-lg sm:text-xl text-white/90 max-w-2xl mx-auto mb-8 leading-relaxed">
      We provide mid to large mining operations complex digital work instructions, via easy to use, in the field software solutions with effective processes and methodologies for complete job management and safe execution.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href="/take-action"
        class="px-8 py-3 bg-emi-gold text-white font-semibold rounded-lg hover:bg-emi-gold-dark transition-colors text-lg"
      >
        Get Started
      </a>
      <a
        href="/software"
        class="px-8 py-3 border-2 border-white text-white font-semibold rounded-lg hover:bg-white/10 transition-colors text-lg"
      >
        Learn More
      </a>
    </div>
  </div>
</section>
