---
---

<section class="relative min-h-[80vh] flex items-center overflow-hidden">
  <!-- Background image with subtle gradient -->
  <div class="absolute inset-0">
    <img
      src="/images/hero/mining-equipment.jpg"
      alt=""
      class="absolute inset-0 w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 to-black/20"></div>
  </div>

  <div class="relative z-20 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full py-20">
    <div class="max-w-3xl">
      <!-- Logo -->
      <div class="mb-8">
        <div class="glass-panel-light rounded-lg px-4 py-2 inline-block">
          <img
            src="/images/emi-logo.jpeg"
            alt="Equipment Management International"
            class="h-9 sm:h-12 w-auto"
          />
        </div>
      </div>

      <!-- Heading in glass panel -->
      <div class="glass-panel rounded-xl px-6 py-5 sm:px-8 sm:py-6 mb-6 inline-block">
        <h1 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-white leading-tight">
          Complex Digital Work Instructions, Shared Simply
        </h1>
        <p class="mt-3 text-base sm:text-lg text-white/80 leading-relaxed max-w-xl">
          Streamlined maintenance software for mid to large mining operations, with effective processes for complete job management.
        </p>
      </div>

      <!-- CTA row -->
      <div class="flex flex-wrap items-center gap-3 mb-6">
        <a href="/take-action" class="btn btn-primary btn-lg">
          Get Started
        </a>
        <a href="/software" class="btn btn-lg glass-panel-light text-white hover:bg-white/20 border-0">
          Explore Software
        </a>
      </div>

      <!-- Sensory data link -->
      <a href="/sensory-based-data" class="glass-panel-light rounded-lg px-4 py-2.5 inline-flex items-center gap-2 text-sm text-primary font-medium hover:bg-white/15 transition-colors">
        Sensory Based Data — The Missing Link
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
      </a>
    </div>
  </div>
</section>
