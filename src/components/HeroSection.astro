---
---

<section class="hero min-h-[75vh] relative overflow-hidden">
  <!-- Background image with stronger overlay for text readability -->
  <div class="absolute inset-0">
    <img
      src="/images/hero/mining-equipment.jpg"
      alt=""
      class="absolute inset-0 w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-black/50 to-black/70"></div>
  </div>

  <div class="hero-content relative z-20 text-center py-20">
    <div class="max-w-3xl">
      <!-- EMI Logo -->
      <div class="flex justify-center mb-10">
        <div class="bg-white/95 rounded-lg px-5 py-2.5 shadow-lg">
          <img
            src="/images/emi-logo.jpeg"
            alt="Equipment Management International"
            class="h-10 sm:h-14 w-auto"
          />
        </div>
      </div>

      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white leading-tight mb-6 hero-text-shadow">
        Complex Digital Work Instructions, Shared Simply
      </h1>
      <p class="text-lg text-white/90 max-w-2xl mx-auto mb-10 leading-relaxed hero-text-shadow">
        Streamlined maintenance software for mid to large mining operations. Effective processes and methodologies for complete job management and safe execution.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center mb-10">
        <a href="/take-action" class="btn btn-primary btn-lg">
          Get Started
        </a>
        <a href="/software" class="btn btn-lg bg-white/15 border-white/30 text-white hover:bg-white/25 hover:border-white/50 backdrop-blur-sm">
          Learn More
        </a>
      </div>

      <a href="/sensory-based-data" class="inline-block group">
        <p class="text-base text-emi-gold font-medium group-hover:text-emi-gold-light transition-colors hero-text-shadow">
          Collecting sensory based data to integrate with sensor based data platforms &rarr;
        </p>
      </a>
    </div>
  </div>
</section>
