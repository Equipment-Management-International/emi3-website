---
interface Props {
  transparent?: boolean;
}
const { transparent = false } = Astro.props;

const aboutLinks = [
  { label: 'What We Do', desc: 'Our approach & results', href: '/what-we-do' },
  { label: 'Projects', desc: 'Case studies', href: '/projects' },
];

const maintenanceProducts = [
  { label: 'ZoneMaintenance', desc: 'Mobile equipment maintenance', href: '/zonemaintenance' },
  { label: 'RouteMaintenance', desc: 'Fixed plant inspections', href: '/routemaintenance' },
];

const statusProducts = [
  { label: 'SafetyStatus', desc: 'Safety audits & inspections', href: '/safetystatus' },
  { label: 'ComponentStatus', desc: 'Component rebuild instructions', href: '/componentstatus' },
  { label: 'EquipmentStatus', desc: 'Equipment compliance audits', href: '/software-status-suite' },
  { label: 'EnviroStatus', desc: 'Environmental monitoring', href: '/software-status-suite' },
];
---

<header class="fixed top-0 left-0 right-0 z-50">
  <div
    class:list={[
      'navbar px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto min-h-16 lg:min-h-20',
      transparent ? 'text-white' : 'text-base-content',
    ]}
  >
    {/* ── Logo ── */}
    <div class="navbar-start">
      <a
        href="/"
        class:list={[
          'flex items-center rounded-lg cursor-pointer',
          transparent ? 'bg-white/95 px-3 py-1' : '',
        ]}
      >
        <img
          src="/images/emi-logo.jpeg"
          alt="Equipment Management International"
          class="h-8 sm:h-10 w-auto"
        />
      </a>
    </div>

    {/* ── Desktop: 5 top-level nav items ── */}
    <div class="navbar-center hidden lg:flex items-center gap-0.5">

      {/* 1. About (dropdown) */}
      <div class="relative group">
        <button
          class:list={[
            'cursor-pointer px-3 py-2 text-[0.95rem] font-medium transition-colors inline-flex items-center gap-1',
            transparent
              ? 'text-white/90 hover:text-white'
              : 'text-base-content/80 hover:text-base-content',
          ]}
        >
          About
          <svg class="w-3.5 h-3.5 opacity-50" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg>
        </button>
        <div class="absolute top-full left-0 pt-3 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
          <div class="bg-base-100 text-base-content rounded-xl shadow-2xl border border-base-300 p-3 w-[240px]">
            {aboutLinks.map((item) => (
              <a href={item.href} class="cursor-pointer block rounded-lg px-3 py-2.5 hover:bg-base-200 transition-colors group/item">
                <div class="font-medium text-sm text-base-content group-hover/item:text-primary transition-colors">{item.label}</div>
                <div class="text-xs text-base-content/60">{item.desc}</div>
              </a>
            ))}
          </div>
        </div>
      </div>

      {/* 2. Software (mega-menu) */}
      <div class="relative group">
        <button
          class:list={[
            'cursor-pointer px-3 py-2 text-[0.95rem] font-medium transition-colors inline-flex items-center gap-1',
            transparent
              ? 'text-white/90 hover:text-white'
              : 'text-base-content/80 hover:text-base-content',
          ]}
        >
          Software
          <svg class="w-3.5 h-3.5 opacity-50" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg>
        </button>
        <div class="absolute top-full left-1/2 -translate-x-1/2 pt-3 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
          <div class="bg-base-100 text-base-content rounded-xl shadow-2xl border border-base-300 p-6 w-[540px]">
            <div class="grid grid-cols-2 gap-6">
              <div>
                <a href="/software" class="cursor-pointer text-xs font-semibold text-primary uppercase tracking-wider mb-3 block hover:underline">
                  Maintenance Suite
                </a>
                <div class="space-y-1">
                  {maintenanceProducts.map((item) => (
                    <a href={item.href} class="cursor-pointer block rounded-lg px-3 py-2.5 hover:bg-base-200 transition-colors group/item">
                      <div class="font-medium text-sm text-base-content group-hover/item:text-primary transition-colors">{item.label}</div>
                      <div class="text-xs text-base-content/60">{item.desc}</div>
                    </a>
                  ))}
                </div>
              </div>
              <div>
                <a href="/software-status-suite" class="cursor-pointer text-xs font-semibold text-primary uppercase tracking-wider mb-3 block hover:underline">
                  Status Suite
                </a>
                <div class="space-y-1">
                  {statusProducts.map((item) => (
                    <a href={item.href} class="cursor-pointer block rounded-lg px-3 py-2.5 hover:bg-base-200 transition-colors group/item">
                      <div class="font-medium text-sm text-base-content group-hover/item:text-primary transition-colors">{item.label}</div>
                      <div class="text-xs text-base-content/60">{item.desc}</div>
                    </a>
                  ))}
                </div>
              </div>
            </div>
            <div class="border-t border-base-300 mt-4 pt-4">
              <a href="/sensory-based-data" class="cursor-pointer text-sm text-base-content/70 hover:text-primary transition-colors inline-flex items-center gap-1">
                Sensory Based Data — The Missing Link
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
              </a>
            </div>
          </div>
        </div>
      </div>

      {/* 3. Magnom (direct link) */}
      <a
        href="/magnom"
        class:list={[
          'cursor-pointer px-3 py-2 text-[0.95rem] font-medium transition-colors',
          transparent
            ? 'text-white/90 hover:text-white'
            : 'text-base-content/80 hover:text-base-content',
        ]}
      >
        Magnom
      </a>

      {/* 4. News (direct link) */}
      <a
        href="/news"
        class:list={[
          'cursor-pointer px-3 py-2 text-[0.95rem] font-medium transition-colors',
          transparent
            ? 'text-white/90 hover:text-white'
            : 'text-base-content/80 hover:text-base-content',
        ]}
      >
        News
      </a>

      {/* 5. Contact (direct link) */}
      <a
        href="/contact"
        class:list={[
          'cursor-pointer px-3 py-2 text-[0.95rem] font-medium transition-colors',
          transparent
            ? 'text-white/90 hover:text-white'
            : 'text-base-content/80 hover:text-base-content',
        ]}
      >
        Contact
      </a>
    </div>

    {/* ── CTA + Mobile hamburger ── */}
    <div class="navbar-end gap-2">
      <a
        href="/take-action"
        class="hidden lg:inline-flex cursor-pointer text-[0.95rem] font-semibold px-5 py-2 rounded-lg bg-primary text-primary-content hover:bg-primary/90 transition-colors"
      >
        Take Action
      </a>

      <button
        id="mobile-menu-btn"
        class:list={[
          'lg:hidden p-2 rounded-lg cursor-pointer',
          transparent ? 'text-white hover:bg-white/10' : 'text-base-content hover:bg-base-200',
        ]}
        aria-label="Open menu"
      >
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
      </button>
    </div>
  </div>

  {/* Background layer */}
  <div
    class:list={[
      'absolute inset-0 -z-10 border-b transition-colors',
      transparent
        ? 'bg-black/40 backdrop-blur-md border-white/10'
        : 'bg-base-100/95 backdrop-blur-md border-base-300',
    ]}
  ></div>
</header>

{/* ── Mobile slide-out menu ── */}
<div id="mobile-menu" class="fixed inset-0 z-[60] hidden">
  <div id="mobile-backdrop" class="absolute inset-0 bg-black/50"></div>

  <div class="absolute top-0 right-0 bottom-0 w-80 max-w-[85vw] bg-base-100 shadow-2xl overflow-y-auto">
    <div class="flex items-center justify-between p-4 border-b border-base-300">
      <img src="/images/emi-logo.jpeg" alt="EMI" class="h-8 w-auto" />
      <button id="mobile-close-btn" class="cursor-pointer p-2 rounded-lg hover:bg-base-200" aria-label="Close menu">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
      </button>
    </div>

    <div class="p-4 space-y-6">
      {/* About */}
      <div>
        <p class="text-xs font-semibold text-primary uppercase tracking-wider mb-2 px-2">About</p>
        <div class="space-y-0.5">
          {aboutLinks.map((item) => (
            <a href={item.href} class="cursor-pointer block px-3 py-2 rounded-lg text-base hover:bg-base-200">{item.label}</a>
          ))}
        </div>
      </div>

      {/* Software */}
      <div>
        <p class="text-xs font-semibold text-primary uppercase tracking-wider mb-2 px-2">Software</p>
        <div class="space-y-0.5">
          <a href="/software" class="cursor-pointer block px-3 py-2 rounded-lg text-base font-medium hover:bg-base-200">Maintenance Suite</a>
          {maintenanceProducts.map((item) => (
            <a href={item.href} class="cursor-pointer block px-3 py-2 rounded-lg text-base text-base-content/80 hover:bg-base-200 pl-6">{item.label}</a>
          ))}
          <a href="/software-status-suite" class="cursor-pointer block px-3 py-2 rounded-lg text-base font-medium hover:bg-base-200 mt-2">Status Suite</a>
          {statusProducts.map((item) => (
            <a href={item.href} class="cursor-pointer block px-3 py-2 rounded-lg text-base text-base-content/80 hover:bg-base-200 pl-6">{item.label}</a>
          ))}
          <a href="/sensory-based-data" class="cursor-pointer block px-3 py-2 rounded-lg text-base text-base-content/80 hover:bg-base-200 pl-6">Sensory Based Data</a>
        </div>
      </div>

      {/* Direct links */}
      <div>
        <div class="space-y-0.5">
          <a href="/magnom" class="cursor-pointer block px-3 py-2 rounded-lg text-base hover:bg-base-200">Magnom Filtration</a>
          <a href="/news" class="cursor-pointer block px-3 py-2 rounded-lg text-base hover:bg-base-200">News & Blogs</a>
        </div>
      </div>

      {/* CTAs */}
      <div class="space-y-2 pt-2 border-t border-base-300">
        <a href="/contact" class="cursor-pointer btn btn-outline btn-primary w-full">Contact Us</a>
        <a href="/take-action" class="cursor-pointer btn btn-primary w-full">Take Action</a>
      </div>
    </div>
  </div>
</div>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const closeBtn = document.getElementById('mobile-close-btn');
  const backdrop = document.getElementById('mobile-backdrop');
  const menu = document.getElementById('mobile-menu');

  function openMenu() { menu?.classList.remove('hidden'); document.body.style.overflow = 'hidden'; }
  function closeMenu() { menu?.classList.add('hidden'); document.body.style.overflow = ''; }

  menuBtn?.addEventListener('click', openMenu);
  closeBtn?.addEventListener('click', closeMenu);
  backdrop?.addEventListener('click', closeMenu);
  menu?.querySelectorAll('a').forEach(link => link.addEventListener('click', closeMenu));
</script>
