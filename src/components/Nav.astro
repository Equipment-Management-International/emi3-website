---
interface Props {
  transparent?: boolean;
}
const { transparent = false } = Astro.props;

const navLinks = [
  {
    label: 'About',
    children: [
      { label: 'What We Do', href: '/what-we-do' },
      { label: 'Projects', href: '/projects' },
      { label: 'Magnom Filtration', href: '/magnom' },
      { label: 'Contact', href: '/contact' },
    ],
  },
  {
    label: 'Software',
    children: [
      { label: 'Maintenance', href: '/software' },
      { label: 'Status Suite', href: '/software-status-suite' },
    ],
  },
  { label: 'Sensory Based Data', href: '/sensory-based-data' },
  { label: 'News & Blogs', href: '/news' },
  { label: 'Take Action', href: '/take-action', cta: true },
];
---

<header
  class:list={[
    'fixed top-0 left-0 right-0 z-50 backdrop-blur-md border-b transition-colors',
    transparent
      ? 'bg-black/40 border-white/10'
      : 'bg-white/90 border-gray-200',
  ]}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 lg:h-20">
      <!-- Logo -->
      <a href="/" class:list={[
        'flex items-center rounded-lg',
        transparent ? 'bg-white/90 px-3 py-1' : '',
      ]}>
        <img
          src="/images/emi-logo.jpeg"
          alt="Equipment Management International"
          class="h-8 sm:h-10 w-auto"
        />
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden lg:flex items-center gap-1">
        {navLinks.map((link) => (
          link.children ? (
            <div class="relative group">
              <button class:list={[
                'px-3 py-2 text-sm font-medium rounded-lg transition-colors',
                transparent
                  ? 'text-white/90 hover:text-white hover:bg-white/10'
                  : 'text-gray-700 hover:text-gray-900 hover:bg-gray-100',
              ]}>
                {link.label}
                <svg class="inline-block w-4 h-4 ml-1" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
                </svg>
              </button>
              <div class="absolute top-full left-0 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
                <div class="bg-white rounded-xl shadow-lg border border-gray-200 py-2 min-w-[200px]">
                  {link.children.map((child) => (
                    <a href={child.href} class="block px-4 py-2 text-sm text-gray-700 hover:bg-emi-gray hover:text-emi-gold-dark transition-colors">
                      {child.label}
                    </a>
                  ))}
                </div>
              </div>
            </div>
          ) : link.cta ? (
            <a href={link.href} class="ml-2 px-5 py-2 text-sm font-semibold bg-emi-gold text-white rounded-lg hover:bg-emi-gold-dark transition-colors">
              {link.cta && link.label}
            </a>
          ) : (
            <a href={link.href} class:list={[
              'px-3 py-2 text-sm font-medium rounded-lg transition-colors',
              transparent
                ? 'text-white/90 hover:text-white hover:bg-white/10'
                : 'text-gray-700 hover:text-gray-900 hover:bg-gray-100',
            ]}>
              {link.label}
            </a>
          )
        ))}
      </nav>

      <!-- Mobile hamburger -->
      <button
        id="mobile-menu-btn"
        class:list={[
          'lg:hidden p-2 rounded-lg',
          transparent ? 'text-white' : 'text-gray-700',
        ]}
        aria-label="Open menu"
      >
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="lg:hidden hidden bg-white border-t border-gray-200">
    <div class="px-4 py-4 space-y-1">
      {navLinks.map((link) => (
        link.children ? (
          link.children.map((child) => (
            <a href={child.href} class="block px-3 py-2 text-sm text-gray-700 hover:bg-emi-gray rounded-lg">
              {child.label}
            </a>
          ))
        ) : (
          <a
            href={link.href}
            class:list={[
              'block px-3 py-2 text-sm rounded-lg',
              link.cta
                ? 'bg-emi-gold text-white font-semibold text-center mt-2'
                : 'text-gray-700 hover:bg-emi-gray',
            ]}
          >
            {link.label}
          </a>
        )
      ))}
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
