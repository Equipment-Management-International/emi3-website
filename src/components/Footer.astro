---
const currentYear = new Date().getFullYear();

const productLinks = [
  { label: 'ZoneMaintenance', href: '/zonemaintenance' },
  { label: 'RouteMaintenance', href: '/routemaintenance' },
  { label: 'ComponentStatus', href: '/componentstatus' },
  { label: 'SafetyStatus', href: '/safetystatus' },
  { label: 'EquipmentStatus', href: '/software-status-suite' },
  { label: 'EnviroStatus', href: '/software-status-suite' },
];

const companyLinks = [
  { label: 'What We Do', href: '/what-we-do' },
  { label: 'Projects', href: '/projects' },
  { label: 'News & Blogs', href: '/news' },
  { label: 'Contact', href: '/contact' },
];

const legalLinks = [
  { label: 'Privacy Policy', href: '/privacy-policy' },
  { label: 'Terms of Use', href: '/term-of-use' },
];
---

<div class="bg-neutral text-neutral-content">
  <!-- Gold accent bar -->
  <div class="h-1 bg-primary"></div>

  <!-- Main footer -->
  <footer class="footer sm:footer-horizontal max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16">
    <!-- Brand -->
    <aside>
      <a href="/" class="block mb-2">
        <span class="text-lg font-bold text-primary">EMI</span>
        <span class="text-sm font-medium text-neutral-content/80 ml-1">Equipment Management International</span>
      </a>
      <p class="text-sm text-neutral-content/70">
        Complex digital work instructions,<br />shared simply.
      </p>
      <p class="text-sm text-neutral-content/70 mt-1">
        Serving Tier 1 and 2 mining operations since 2005.
      </p>
      <div class="text-sm text-neutral-content/50 mt-3 space-y-0.5">
        <p>Equipment Management International P/L</p>
        <p>ABN 45 112 360 273</p>
        <p>Burnie, TAS, 7320, Australia</p>
      </div>
    </aside>

    <!-- Products -->
    <nav>
      <h6 class="footer-title text-primary opacity-100">Products</h6>
      {productLinks.map((link) => (
        <a href={link.href} class="link link-hover text-neutral-content/70 hover:text-neutral-content text-base">
          {link.label}
        </a>
      ))}
    </nav>

    <!-- Company -->
    <nav>
      <h6 class="footer-title text-primary opacity-100">Company</h6>
      {companyLinks.map((link) => (
        <a href={link.href} class="link link-hover text-neutral-content/70 hover:text-neutral-content text-base">
          {link.label}
        </a>
      ))}
    </nav>

    <!-- Legal -->
    <nav>
      <h6 class="footer-title text-primary opacity-100">Legal</h6>
      {legalLinks.map((link) => (
        <a href={link.href} class="link link-hover text-neutral-content/70 hover:text-neutral-content text-base">
          {link.label}
        </a>
      ))}
    </nav>
  </footer>

  <!-- Copyright bar -->
  <footer class="footer max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 border-t border-neutral-content/10">
    <aside class="grid-flow-col items-center">
      <p class="text-sm text-neutral-content/50">&copy; {currentYear} Equipment Management International P/L. All rights reserved.</p>
    </aside>
    <nav class="md:place-self-center md:justify-self-end">
      <a href="#top" class="link link-hover text-sm text-neutral-content/50 hover:text-primary">Back to Top &uarr;</a>
    </nav>
  </footer>
</div>
