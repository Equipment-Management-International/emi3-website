---
const steps = [
  {
    number: '1',
    title: 'Get in Touch',
    description: 'Contact us for detailed information and access to our demo models.',
  },
  {
    number: '2',
    title: 'Site Review',
    description: "When you're ready, we'll come out to your site and review the current processes.",
  },
  {
    number: '3',
    title: 'Custom Package',
    description: "Together, we'll create a package that suits your requirements, team, and budget.",
  },
  {
    number: '4',
    title: 'Install & Train',
    description: "Once installed, we'll provide in-field user training at all levels.",
  },
];
---

<section class="py-16 sm:py-24 bg-neutral text-neutral-content" id="get-started">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-14">
      <h2 class="section-heading text-neutral-content mb-3">
        We Customise Packages for Your Site
      </h2>
      <p class="text-lg text-neutral-content/60">
        Simple to get started
      </p>
    </div>

    <!-- Steps as cards on a grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-14">
      {steps.map((step) => (
        <div class="text-center">
          <div class="w-12 h-12 rounded-full bg-primary text-primary-content flex items-center justify-center text-xl font-bold mx-auto mb-4">
            {step.number}
          </div>
          <h3 class="section-subheading text-neutral-content mb-2">{step.title}</h3>
          <p class="text-neutral-content/60 text-base leading-relaxed">{step.description}</p>
        </div>
      ))}
    </div>

    <div class="text-center">
      <a href="/take-action" class="btn btn-primary btn-lg">
        Take Action
      </a>
    </div>
  </div>
</section>
