---
const steps = [
  {
    number: '1',
    title: 'Get in Touch',
    description: 'Contact us for detailed information and access to our demo models.',
  },
  {
    number: '2',
    title: 'Site Review',
    description: "When you're ready, we'll come out to your site and review the current processes.",
  },
  {
    number: '3',
    title: 'Custom Package',
    description: "Together, we'll create a package that suits your requirements, team, and budget.",
  },
  {
    number: '4',
    title: 'Install & Train',
    description: "Once installed, we'll provide in-field user training at all levels and ensure the system is performing seamlessly.",
  },
];
---

<section class="py-16 sm:py-24 bg-emi-charcoal" id="get-started">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="text-2xl sm:text-3xl font-bold text-white uppercase tracking-wide mb-4">
        We Customise Packages for Your Site
      </h2>
      <p class="text-lg text-gray-400">
        It's simple to get started today
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8">
      {steps.map((step) => (
        <div class="text-center">
          <div class="w-14 h-14 rounded-full bg-emi-gold text-emi-black font-extrabold text-xl flex items-center justify-center mx-auto mb-4">
            {step.number}
          </div>
          <h3 class="text-lg font-bold text-white mb-2">{step.title}</h3>
          <p class="text-sm text-gray-400 leading-relaxed">{step.description}</p>
        </div>
      ))}
    </div>

    <div class="text-center mt-12">
      <a
        href="/take-action"
        class="inline-block px-8 py-3 bg-emi-gold text-emi-black font-semibold rounded-lg hover:bg-emi-gold-light transition-colors text-lg"
      >
        Take Action
      </a>
    </div>
  </div>
</section>
