---
/**
 * Reusable hero for inner pages.
 * Modern glass-panel design with background image.
 * Supports embedded stats, left or center alignment.
 */
interface Props {
  title: string;
  subtitle?: string;
  image?: string;
  align?: 'left' | 'center';
  compact?: boolean;
}

const {
  title,
  subtitle,
  image,
  align = 'left',
  compact = false,
} = Astro.props;
---

<section class:list={[
  'relative flex items-end overflow-hidden',
  compact ? 'min-h-[35vh] py-12' : 'min-h-[55vh] py-16 sm:py-20',
]}>
  {/* Background */}
  {image ? (
    <div class="absolute inset-0">
      <img src={image} alt="" class="absolute inset-0 w-full h-full object-cover" loading="eager" />
      <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 to-black/20"></div>
    </div>
  ) : (
    <div class="absolute inset-0 bg-neutral"></div>
  )}

  <div class:list={[
    'relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full',
    align === 'center' ? 'text-center' : '',
  ]}>
    <div class:list={[align === 'center' ? 'max-w-3xl mx-auto' : 'max-w-2xl']}>
      {/* Glass-backed text for readability */}
      <div class="glass-panel rounded-xl px-6 py-5 sm:px-8 sm:py-6 inline-block mb-4">
        <h1 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-white leading-tight">
          {title}
        </h1>
        {subtitle && (
          <p class="mt-3 text-base sm:text-lg text-white/80 leading-relaxed max-w-xl">
            {subtitle}
          </p>
        )}
      </div>

      {/* Slot for stats bar, CTAs, or extra content */}
      <slot />
    </div>
  </div>
</section>
