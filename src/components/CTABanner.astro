---
/**
 * Reusable CTA banner section.
 * Dark background with heading, optional subtitle, and action buttons.
 */
interface Props {
  heading: string;
  subtitle?: string;
  primaryLabel?: string;
  primaryHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
}

const {
  heading,
  subtitle,
  primaryLabel = 'Take Action',
  primaryHref = '/take-action',
  secondaryLabel,
  secondaryHref,
} = Astro.props;
---

<section class="py-16 sm:py-20 bg-neutral text-neutral-content">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-2xl sm:text-3xl font-bold mb-4">{heading}</h2>
    {subtitle && <p class="text-lg text-neutral-content/80 mb-8">{subtitle}</p>}
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href={primaryHref} class="btn btn-primary btn-lg">{primaryLabel}</a>
      {secondaryLabel && secondaryHref && (
        <a href={secondaryHref} class="btn btn-outline border-neutral-content/30 text-neutral-content hover:bg-neutral-content/10 hover:border-neutral-content/50 btn-lg">
          {secondaryLabel}
        </a>
      )}
    </div>
  </div>
</section>
