---
const items = [
  'Mobile equipment maintenance',
  'Fixed plant maintenance',
  'Component rebuilds',
  'Equipment rental compliance',
  'Environmental audits',
];
---

<section class="py-16 sm:py-24 bg-neutral text-neutral-content">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="section-heading text-neutral-content mb-4">
        Multi-Level Responses, Standardised Sequences, and In-Built Trigger Actions
      </h2>
      <p class="text-primary font-medium text-lg mb-10">
        Radically improving your asset maintenance safety, quality, and efficiency
      </p>

      <ul class="grid sm:grid-cols-2 gap-3 max-w-lg mx-auto text-left mb-10">
        {items.map((item) => (
          <li class="flex items-center gap-3 text-neutral-content/80">
            <svg class="w-5 h-5 text-primary flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
            </svg>
            <span class="text-base">{item}</span>
          </li>
        ))}
      </ul>

      <a href="/take-action" class="btn btn-primary btn-lg">
        Find Out How
      </a>
    </div>
  </div>
</section>
